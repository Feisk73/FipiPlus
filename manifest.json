{
  "manifest_version": 3,
  "name": "FipiPlus",
  "version": "1.0",

  "browser_specific_settings": {
    "gecko": {
      "id": "copokdvabratuha@fipiplus.ru",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/moon.svg", "icons/sun.svg"],
      "matches": ["*://*.fipi.ru/*"]
    }
  ],
  "icons": {
    "48": "icons/icon-48.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.fipi.ru/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "permissions": ["activeTab", "storage"]
}
